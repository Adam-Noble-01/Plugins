{
    "meta": {
        "fileName"          : "Na__DataLib__CoreIndex__Tags__.json",
        "description"       : "Single source of truth for all Noble Architecture standard SketchUp tags (layers). Drives the TrueVision3D GlbBuilder export segmentation, storey detection, Layout linework thickness mapping, and tag creation. All field names use domain prefixes: Tag__ (core identity), Glb__ (GLB exporter), Storey__ (storey system), Layout__ (SketchUp Layout).",
        "version"           : "2.0.0",
        "lastUpdated"       : "15-Mar-2026",
        "namingConvention"  : "Tags use the format: {NN}__{Category}__{Subcategory}. The numeric prefix controls sort order and export range grouping. Double underscores separate all name parts.",
        "fieldPrefixes"     : {
            "Tag__"    : "Core SketchUp tag identity (name, description)",
            "Glb__"    : "GLB exporter behaviour (export ranges, exclusion, filename stem)",
            "Storey__" : "Storey-based export system (container flag, element name)",
            "Layout__" : "SketchUp Layout integration (edge colour mapping, usage notes)"
        },
        "skipRanges"        : [0, 2, 3, 4, 5, 6],
        "skipRangesNote"    : "Tags with these numeric IDs are ignored by the GLB exporter and not exported.",
        "GitHub__RepoUrl"   : "https://github.com/Adam-Noble-01/Plugins/tree/main/Na__Common__DataLib__CoreSuEntityStandards",
        "Data__URL"         : "https://raw.githubusercontent.com/Adam-Noble-01/Plugins/main/Na__Common__DataLib__CoreSuEntityStandards/Na__DataLib__CoreIndex__Tags__.json"
    },

