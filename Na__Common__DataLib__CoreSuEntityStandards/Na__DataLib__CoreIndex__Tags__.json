    "ExportExclusions": {
        "Description"              : "Tags and patterns used by the GlbBuilder to control entity visibility during GLB export. FullyExcludedTagNames are completely invisible in the GLB. TreatAsUntaggedTagNames are exported as Layer0 geometry (visible in 3D viewer but not segmented by tag).",
        "PatternExclusionRegex"    : "^TrueVision_.*_DoNotExportGLTF$",
        "PatternExclusionNote"     : "Any tag matching this pattern (TrueVision_{wildcard}_DoNotExportGLTF) is excluded from export at all nesting depths.",
        "FullyExcludedTagNames"    : [
            "02__Linetype__DoorSwings",
            "02__ClearanceLines"
        ],
        "FullyExcludedNote"        : "Entities on these tags are completely skipped during GLB export at any nesting depth.",
        "TreatAsUntaggedTagNames"  : [
