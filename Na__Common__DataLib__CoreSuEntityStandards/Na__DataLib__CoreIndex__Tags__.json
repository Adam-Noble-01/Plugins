{
    "meta": {
        "fileName"          : "Na__DataLib__CoreIndex__Tags__.json",
        "description"       : "Single source of truth for all Noble Architecture standard SketchUp tags (layers). Used by TrueVision3D GlbBuilder to create standardised tags in the active model and to segment GLB exports by numeric tag range. Each tag entry includes the canonical SketchUp tag name, description, and where applicable the numeric export range used by the GLB exporter.",
        "version"           : "1.0.0",
        "lastUpdated"       : "15-Mar-2026",
        "sourceFiles"       : [
            "Na__TrueVision__GlbBuilderUtility__Modules__/Na__TrueVision__GlbBuilder__TagsIndex__.json",
            "Na__TrueVision__GlbBuilderUtility__Modules__/Na__TrueVision__GlbBuilder__Main__.rb (TAG_RANGES constant)"
        ],
        "namingConvention"  : "Tags use a two-part format: {NN}__{Category}__{Subcategory}. The numeric prefix controls sort order and export range grouping. Double underscores separate all name parts.",
        "divergenceNote"    : "Two formats currently exist in the codebase. (1) Short format used in TagsIndex.json and adopted here: '10__ExistingBuilding', '11__ExistingBuilding__Walls'. (2) Legacy TrueVision__ prefix format used in TAG_RANGES in Main.rb: 'TrueVision__MainBuildingModel__ExistingWalls'. Both formats are documented here for traceability. The short NN__ format is the canonical going-forward convention. The TrueVision__ names are preserved in the LegacyTagName field for migration reference.",
        "exportNote"        : "ExportRangeNums lists the integer tag numbers that the GlbBuilder uses to segment GLB output files. Tags with ExportRangeNums are exported as separate GLB segments. Tags with no range are either utility tags or storey containers.",
        "skipRanges"        : [0, 2, 3, 4, 5, 6],
        "skipRangesNote"    : "Tags with these numeric IDs are ignored by the GLB exporter and not exported."
    },

