{
    "meta": {
        "fileName"               : "Na__DataLib__CoreIndex__EdgeMaterials__.json",
        "description"            : "Single source of truth for all Noble Architecture standard edge linework colours. Used by Na__EdgeUtil__PaintDeepNestedEdges to create SketchUp edge materials and populate the colour palette UI. Each MTE colour key becomes the SketchUp material name when applied to edges.",
        "version"                : "2.0.0",
        "lastUpdated"            : "15-Mar-2026",
        "sourceFiles"            : [
            "Na__EdgeUtil__PaintDeepNestedEdges__Modules__/Na__EdgeUtil__PaintDeepNestedEdges__EdgeConfigData__.json (v1.0.0 - superseded)"
        ],
        "namingConvention"       : "Format: MTE{NNN}__{Category}__{Variant}. MTE prefix + 3-digit zero-padded number + __ + descriptor. The MTE prefix is required for the edge material lookup system to recognise an entry as indexed. The 'Default' key is a special reserved entry that resets the edge to SketchUp's default colour (no material created).",
        "indexPattern"           : "^MTE\\d{3}__",
        "uiDefaults": {
            "DefaultColourKey"         : "Default",
            "DynamicPaletteSlotCount"  : 4,
            "DynamicPaletteDefaultKey" : "MTE109__LineColour__White"
        },
        "GitHub__RepoUrl"        : "https://github.com/Adam-Noble-01/Plugins/tree/main/Na__Common__DataLib__CoreSuEntityStandards",
        "Data__URL"              : "https://raw.githubusercontent.com/Adam-Noble-01/Plugins/main/Na__Common__DataLib__CoreSuEntityStandards/Na__DataLib__CoreIndex__EdgeMaterials__.json"
    },

    "NamingRationale": {
        "Summary"            : "Edge material names follow the same prefix-series pattern as face materials (MAT{NNN}__) to create a unified, parseable naming system across all Na__ material types.",
        "PrefixBreakdown"    : {
            "M"              : "Material - identifies this as a SketchUp material entity",
            "T"              : "Type - second character for sub-type qualification",
            "E"              : "Edge - specifies this material is used on edges, not faces",
            "Full_Prefix"    : "MTE - Material Type Edge"
        },
        "NumberingLogic"     : "3-digit zero-padded sequential number (001-999). Series are organised in hundreds: MTE000__ = reserved/default, MTE100__ = greyscale series, MTE200__ = accent colour series. This mirrors the MAT series structure (MAT000__, MAT100__, MAT300__, etc.) and leaves full hundreds free for future series expansion.",
        "ComparisonToMAT"    : "MAT{NNN}__ is used for face/surface materials. MTE{NNN}__ is used for edge/linework materials. Both share the same structural rules: prefix + 3-digit number + __ + category + __ + variant. This makes regex detection trivial and keeps the SketchUp materials palette sorted and grouped consistently.",
        "PreviousFormat"     : "The original format was '00_XX__LineColour__Descriptor' (e.g. 00_01__LineColour__AbsoluteBlack). This has been superseded by MTE{NNN}__ in version 2.0.0 of this file. Any existing SketchUp models using the old material names will need a one-time migration to the new MTE names."
    },

